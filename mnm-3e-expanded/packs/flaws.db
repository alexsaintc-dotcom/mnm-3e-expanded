{"_id":"3cwhuepb1k","ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"exportSource":null,"coreVersion":"13.350","systemId":"mutants-and-masterminds-3e","systemVersion":"1.39.13"},"name":"Distracting","type":"modificateur","img":"systems/mutants-and-masterminds-3e/assets/icons/pouvoir.svg","system":{"type":"defaut","description":"<p>Using a Distracting effect requires so much concentration or effort that you are vulnerable until the start of your next turn.</p><p>–1 cost per rank.</p>","notes":"<p>Using a Distracting effect requires so much concentration or effort that you are vulnerable until the start of your next turn.</p><p>–1 cost per rank.</p>","cout":{"fixe":false,"rang":true,"value":-1}}}
{"_id":"5uvz97zrq8v","ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"exportSource":null,"coreVersion":"13.350","systemId":"mutants-and-masterminds-3e","systemVersion":"1.39.13"},"name":"Grab-Based","type":"modificateur","img":"systems/mutants-and-masterminds-3e/assets/icons/pouvoir.svg","system":{"type":"defaut","description":"<p>An attack with this flaw requires you to successfully grab and hold a target before the effect can be used.</p><p>–1 cost per rank.</p>","notes":"<p>An attack with this flaw requires you to successfully grab and hold a target before the effect can be used.</p><p>–1 cost per rank.</p>","cout":{"fixe":false,"rang":true,"value":-1}}}
