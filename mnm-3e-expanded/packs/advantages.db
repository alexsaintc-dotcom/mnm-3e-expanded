{"_id":"sgx3hcdbsb9","name":"Evasion","type":"talent","img":"systems/mutants-and-masterminds-3e/assets/icons/talent.svg","system":{"description":"<p>+2 circumstance bonus to Dodge checks to avoid area effects. Rank 2 increases bonus to +5.</p>","rang":2},"effects":[],"flags":{}}
{"_id":"svxcw4ea23c","name":"Attractive","type":"talent","img":"systems/mutants-and-masterminds-3e/assets/icons/talent.svg","system":{"description":"<p>+2 circumstance bonus on Deception and Persuasion checks (+5 for rank 2).</p>","rang":1},"effects":[],"flags":{}}
{"_id":"mgdcjd0x3fj","name":"Eidetic Memory","type":"talent","img":"systems/mutants-and-masterminds-3e/assets/icons/talent.svg","system":{"description":"<p>Perfect recall. +5 circumstance bonus on memory checks. Can make Expertise checks as if trained.</p>","rang":1},"effects":[],"flags":{}}
