{"_id":"yumq6gi0dmi","name":"Diehard","type":"talent","img":"systems/mutants-and-masterminds-3e/assets/icons/talent.svg","system":{"description":"<p>Automatically stabilize on the round after your condition becomes dying.</p>","rang":1}}
