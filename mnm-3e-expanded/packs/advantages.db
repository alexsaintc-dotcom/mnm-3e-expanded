{"_id":"hyjenmj8tts","name":"Accurate Attack","type":"talent","img":"systems/mutants-and-masterminds-3e/assets/icons/talent.svg","system":{"description":"<p>When you make an accurate attack, you can take a penalty of up to –5 on the effect modifier of the attack and add the same number (up to +5) to your attack bonus.</p>","rang":1},"effects":[],"flags":{}}
{"_id":"mwf9wxq3wn","name":"Agile Feint","type":"talent","img":"systems/mutants-and-masterminds-3e/assets/icons/talent.svg","system":{"description":"<p>You can use your Acrobatics bonus or movement speed rank in place of Deception to feint and trick in combat.</p>","rang":1},"effects":[{"_id":"effz7sppohn","name":"Agile Feint Bonus","changes":[{"key":"system.competence.acrobaties.bonuses","mode":2,"value":"2","priority":20}],"disabled":false,"transfer":true,"icon":"systems/mutants-and-masterminds-3e/assets/icons/talent.svg"}],"flags":{}}
{"_id":"txbu9sj2m9d","name":"All-out Attack","type":"talent","img":"systems/mutants-and-masterminds-3e/assets/icons/talent.svg","system":{"description":"<p>When you make an all-out attack, you can take a penalty of up to –5 on your active defenses (Dodge and Parry) and add the same number (up to +5) to your attack bonus.</p>","rang":1},"effects":[],"flags":{}}
