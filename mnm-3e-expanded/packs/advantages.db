{"name":"Animal Empathy","type":"talent","img":"systems/mutants-and-masterminds-3e/assets/icons/talent.svg","system":{"description":"<p>You have a special connection with animals. You can use interaction skills on animals normally, and do not have to speak a language the animal understands.</p>","equipement":false,"rang":1,"edit":true,"listEffectsVariantes":{}},"effects":[],"_id":"jkcksr8qkic"}
{"name":"Artificer","type":"talent","img":"systems/mutants-and-masterminds-3e/assets/icons/talent.svg","system":{"description":"<p>You can use the Expertise: Magic skill to create temporary magical devices.</p>","equipement":false,"rang":1,"edit":true,"listEffectsVariantes":{}},"effects":[],"_id":"anciwodh0br"}
