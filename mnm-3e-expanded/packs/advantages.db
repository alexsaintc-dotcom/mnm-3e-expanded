{"_id":"8v4oyh38k4w","name":"Eidetic Memory","type":"talent","img":"systems/mutants-and-masterminds-3e/assets/icons/talent.svg","system":{"description":"<p>Perfect recall. +5 circumstance bonus on memory checks. Can make Expertise checks as if trained.</p>","rang":1},"effects":[{"name":"Eidetic Memory Bonus","changes":[{"key":"system.competence.investigation.bonuses","mode":2,"value":"5","priority":20}],"disabled":false,"transfer":true,"icon":"systems/mutants-and-masterminds-3e/assets/icons/talent.svg"}]}
{"_id":"jatr0z9wjtp","name":"Animal Empathy","type":"talent","img":"systems/mutants-and-masterminds-3e/assets/icons/talent.svg","system":{"description":"<p>You have a special connection with animals. You can use interaction skills on animals normally.</p>","rang":1},"effects":[{"name":"Animal Empathy Bonus","changes":[{"key":"system.competence.persuasion.bonuses","mode":2,"value":"2","priority":20}],"disabled":false,"transfer":true,"icon":"systems/mutants-and-masterminds-3e/assets/icons/talent.svg"}]}
